{
  "manifest_version": 3,
  "name": "holospaces router",
  "version": "0.0.1",
  "description": "The holospaces router: carries a browser-tab guest's traffic to the internet via Direct Sockets (raw TCP). No node, no proxy.",

  "background": { "service_worker": "background.js" },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "externally_connectable": {
    "matches": ["https://hologram-technologies.github.io/*"]
  },

  "host_permissions": ["*://*/*"],

  "content_scripts": [
    {
      "matches": ["https://hologram-technologies.github.io/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
